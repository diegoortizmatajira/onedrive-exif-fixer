{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "OneDrive EXIF Fixer: Dry-run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "args": [
                "${input:targetPath}",
                "--dry-run",
                "--report",
                "${workspaceFolder}/dry-run-report.csv"
            ],
            "console": "integratedTerminal",
        },
        {
            "name": "OneDrive EXIF Fixer: Apply",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "args": [
                "${input:targetPath}"
            ],
            "console": "integratedTerminal",
        }
    ],
    "inputs": [
        {
            "id": "targetPath",
            "type": "promptString",
            "description": "Path to file or directory to process",
            "default":"/home/storage/Diego-Ortiz/OneDrive/Pictures/Camera Roll/2012/20120815/img036.jpg"
        }
    ]
}
